# ==============================================================================
# Tytul:        dgmgrl-observer-dc.service
# Opis:         systemd unit dla BACKUP Observer FSFO w osrodku DC (primary site).
# Description [EN]: systemd unit for BACKUP FSFO Observer in DC site (primary site).
#
# Autor:        KCB Kris
# Data:         2026-04-23
# Wersja:       1.0
#
# Wymagania [PL]:    - RHEL/OL 7+ z systemd
#                    - Oracle Client 19c+ (dgmgrl w PATH)
#                    - Wallet w /etc/oracle/wallet/observer-dc
#                    - TNS_ADMIN=/etc/oracle/tns/dc z aliasami PRIM_ADMIN, STBY_ADMIN
#                    - Observer registered w brokerze: ADD OBSERVER 'obs_dc' ON '<host>'
# Requirements [EN]: - RHEL/OL 7+ with systemd
#                    - Oracle Client 19c+ (dgmgrl in PATH)
#                    - Wallet at /etc/oracle/wallet/observer-dc
#                    - TNS_ADMIN=/etc/oracle/tns/dc with aliases PRIM_ADMIN, STBY_ADMIN
#
# Uzycie / Usage:
#   sudo cp dgmgrl-observer-dc.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable dgmgrl-observer-dc
#   sudo systemctl start dgmgrl-observer-dc
# ==============================================================================

[Unit]
Description=Data Guard Observer (obs_dc — BACKUP) for FSFO — DC site
Documentation=file:///opt/dba/20260423-FSFO-TAC-guide/FSFO-GUIDE.md
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=oracle
Group=oinstall

Environment=ORACLE_HOME=/u01/app/oracle/product/19.0.0/dbhome_1
Environment=TNS_ADMIN=/etc/oracle/tns/dc
Environment=LD_LIBRARY_PATH=/u01/app/oracle/product/19.0.0/dbhome_1/lib
Environment=NLS_LANG=AMERICAN_AMERICA.AL32UTF8
Environment=TZ=Europe/Warsaw

WorkingDirectory=/var/log/oracle/observer

ExecStart=/u01/app/oracle/product/19.0.0/dbhome_1/bin/dgmgrl \
    -echo \
    -logfile /var/log/oracle/observer/obs_dc_startup.log \
    /@PRIM_ADMIN \
    "START OBSERVER obs_dc IN BACKGROUND FILE='/var/log/oracle/observer/obs_dc.dat' LOGFILE='/var/log/oracle/observer/obs_dc.log'"

ExecStop=/u01/app/oracle/product/19.0.0/dbhome_1/bin/dgmgrl \
    -echo \
    /@PRIM_ADMIN \
    "STOP OBSERVER obs_dc"

Restart=on-failure
RestartSec=30s
TimeoutStartSec=60s
TimeoutStopSec=30s

StandardOutput=journal
StandardError=journal
SyslogIdentifier=dgmgrl-observer-dc

PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/log/oracle /u01/app/oracle
ProtectHome=true

LimitNOFILE=65536
LimitNPROC=16384

[Install]
WantedBy=multi-user.target
